# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URLs
# NEXT_PUBLIC_APP_URL is exposed to the client and used in verification flows.
NEXT_PUBLIC_APP_URL="https://sigce.example.com"

# APP_URL is the server-side fallback URL used for QR links and callbacks.
APP_URL="https://sigce.example.com"

# VERIFICATION_URL lets you override the public verification base URL if needed.
VERIFICATION_URL="https://sigce.example.com/verify"

# Bootstrap admin email
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"

# App session signing
# Required for the server-issued httpOnly session cookie used by middleware and admin APIs.
APP_SESSION_SECRET="replace_with_a_long_random_secret_of_at_least_32_characters"

# Firebase Web SDK
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_web_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef1234567890"

# Firebase Admin SDK
# Preferred: Base64-encoded JSON from the service account file.
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64="BASE64_ENCODED_SERVICE_ACCOUNT_JSON"

# Optional fallback if you cannot provide Base64.
# Keep the JSON in a single line and escape private key newlines as \\n.
FIREBASE_SERVICE_ACCOUNT_KEY="{\"type\":\"service_account\",\"project_id\":\"your-project-id\",\"private_key\":\"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n\",\"client_email\":\"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com\"}"

# Email delivery
GMAIL_USER="noreply@example.com"
GMAIL_APP_PASSWORD="your_gmail_app_password"
